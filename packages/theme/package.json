{
  "name": "@shellraining-blog/theme",
  "version": "1.0.0",
  "author": "shellRaining",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./dist/node/config.js"
  },
  "types": "./dist/node/config.d.ts",
  "main": "./src/index.ts",
  "description": "shellRaining's blog theme",
  "keywords": [
    "vitepress",
    "theme",
    "blog"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf ./dist/ && rolldown -c ./rolldown.config.ts",
    "build:watch": "rolldown -c ./rolldown.config.ts -w",
    "prepublishOnly": "bun run build",
    "test": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "dependencies": {
    "@vueuse/core": "^10.11.1",
    "dayjs": "^1.11.13",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-mathjax3": "^4.3.2",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "viewerjs": "^1.11.7",
    "vue": "^3.5.13"
  },
  "peerDependencies": {
    "vitepress": "^v2.0.0-alpha.3"
  }
}
